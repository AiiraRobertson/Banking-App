            "});"
          ]}}]
        },
        {
          "name": "SEC-CORS-04 Wildcard not combined with credentials",
          "request": {
            "method": "GET",
            "header": [{ "key": "Origin", "value": "http://localhost:5173" }],
            "url": { "raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api","accounts"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
            "const acao = pm.response.headers.get('Access-Control-Allow-Origin');",
