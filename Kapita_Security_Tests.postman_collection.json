            "pm.sendRequest({",
            "  url: pm.collectionVariables.get('baseUrl') + '/api/transactions?limit=5',",
            "  method: 'GET',",
            "  header: { Authorization: 'Bearer ' + pm.collectionVariables.get('userToken') }",
            "}, (err, res) => {",
