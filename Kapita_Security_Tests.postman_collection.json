            "});"
          ]}}]
        },
        {
          "name": "SEC-CORS-03 Preflight from allowed origin",
          "request": {
            "method": "OPTIONS",
            "header": [
              { "key": "Origin", "value": "http://localhost:5173" },
              { "key": "Access-Control-Request-Method", "value": "GET" },
              { "key": "Access-Control-Request-Headers", "value": "authorization" }
            ],
            "url": { "raw": "{{baseUrl}}/api/accounts", "host": ["{{baseUrl}}"], "path": ["api","accounts"] }
          },
          "event": [{ "listen": "test", "script": { "exec": [
